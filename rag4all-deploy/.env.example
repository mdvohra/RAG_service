# Copy to .env before starting:  cp .env.example .env

# Single tenant — one chatbot for your site (signup/login disabled)
DEPLOYMENT_MODE=single_tenant
SECRET_KEY=change-me-use-a-long-random-string
API_KEY=rag_dev_api_key_change_me
WIDGET_KEY=wk_dev_widget_key_change_me

# Where the widget will be embedded
SITE_URL=http://localhost:3000
SITE_URL_ALLOW_LOCALHOST=true

# Local URLs
API_PUBLIC_URL=http://localhost:8000
ADMIN_PUBLIC_URL=http://localhost:8090

# LLM — set your provider and API key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Infrastructure (defaults are fine for local)
POSTGRES_PASSWORD=rag
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=documents
MINIO_SECURE=false
